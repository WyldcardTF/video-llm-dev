# Copy this file to .env and then fill in secrets or project-specific paths.

# Application paths
APP_BASE_DIR=/app
DOTENV_PATH=/app/.env

# Input and output locations
VIDEO_INPUT_DIR="/app/Video Input"
VIDEO_OUTPUT_DIR="/app/Video Output"
PIPELINE_PROJECT_DIR=/app/artifacts/session

# Optional direct file overrides
# If PIPELINE_SOURCE_PATH is empty, the pipeline scans VIDEO_INPUT_DIR for videos.
PIPELINE_SOURCE_PATH=
SCRIPT_INPUT_FILE="/app/Video Input/script.txt"
VOICEOVER_INPUT_FILE=
OUTPUT_FILENAME=draft.mp4

# Intermediate artifact file names
VIDEO_ANALYSES_FILENAME=video_analyses.json
STYLE_PROFILE_FILENAME=style_profile.json
SHOT_PLAN_FILENAME=shot_plan.json
FRAMES_DIR_NAME=frames
AUDIO_DIR_NAME=audio

# Pipeline behavior
SAMPLE_FRAMES=6
TIMELINE_SCAN_POINTS=48
TRANSCRIBE_VOICE=false
TRANSCRIPTION_MAX_SECONDS=60
AUDIO_ANALYSIS_MAX_SECONDS=90
RENDER_FPS=24

# OpenAI
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Docker Compose
COMPOSE_CONTAINER_NAME=video-llm-dev
APP_START_COMMAND=bash
